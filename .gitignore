# ---------------------------------------------
# 1. Python 빌드 및 캐시 파일
# ---------------------------------------------
# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info


# ---------------------------------------------
# 2. 로컬 환경 및 설정 (민감 정보/로컬 전용)
# ---------------------------------------------
# 가상 환경 (모든 venv, .venv 디렉토리 제외)
venv/
.venv/
/.venv

# 환경 변수 파일 (최상위 디렉토리의 .env 파일만 제외)
/.env

# 로컬 캐시 디렉토리
.cache/
/.pytest_cache/
/data/


# ---------------------------------------------
# 4. 데이터 파일 및 결과 등
# ---------------------------------------------
/output
/raw_reports
/docs_cache


# ---------------------------------------------
# 4. OS 및 IDE 관련 파일
# ---------------------------------------------
# # macOS
# .DS_Store

# Windows
Thumbs.db

# IDE (VS Code)
.vscode/

# 로그 및 임시 파일
*.log
*~
